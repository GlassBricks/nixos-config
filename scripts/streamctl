#!/usr/bin/env python3
"""Stream control: bring the stream layout up or tear it down via KWin scripting.

Additive token bag - list any actions to run; `up`/`down` are bundle aliases.

  Groups   up   = factorio spawn place minimize keys   (old stream-setup + libresplit-hotkeys-on)
           down = close kill nokeys                    (old stream-close  + libresplit-hotkeys-off)

  Actions  factorio  launch factorio (default instance, before OBS)
           spawn     launch the stream apps
           place     place windows across monitors
           minimize  minimize extra windows
           close     close stream windows via KWin
           kill      kill orphan procs (factorio, toolkit, vesktop, obs)
           keys      bind libresplit hotkeys (ON)
           nokeys    unbind libresplit hotkeys (OFF)

Layout (place):
  OUT1 (DP-3, left)   : gw | chat | ff1                - equal thirds
  OUT2 (DP-1, center) : untouched
  OUT3 (DP-2, right)  : left col kit(20%) over obs(80%); right col vesk(1/3) over ff3(2/3)
                        + libresplit floating upper-left
  Other windows on OUT1 & OUT3 minimized.

Examples:
  streamctl up                 full setup + hotkeys ON
  streamctl down               close + kill orphans + hotkeys OFF
  streamctl spawn place keys   launch, place, hotkeys ON (no minimize)
  streamctl place minimize     re-place already-running windows
  streamctl keys / streamctl nokeys   toggle libresplit hotkeys only
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import shlex
import subprocess
import time
from pathlib import Path

HOME = Path.home()
OUT1, OUT2, OUT3 = "DP-3", "DP-1", "DP-2"
KITTY_CLASS = "stream-bg-factorio"
SPLIT_W, SPLIT_H = 300, 430
TIMEOUT = 25
KWIN_TIMEOUT = 5.0  # backstop per KWin script run; the end sentinel ends it sooner
GEOM_TOL = 40  # px; Krohnkite re-tiling moves windows far more than this

STREAM_IMAGE  = HOME / "Documents/Factorio/RSNG+/queue1.png"
STREAM_FF1    = "https://docs.google.com/spreadsheets/d/1z6Z9Vp3Abv4sXgnAqKTJ8WCbT_7ZdupdOlDob4eHSv8/edit?gid=0#gid=0"
STREAM_FF2    = "file:///home/ben/opt/factorio-preview-toolkit-linux-v0.1.74/viewer/index.html"
STREAM_TWITCH = "https://dashboard.twitch.tv/u/glassbricks/stream-manager"
BG_DIR        = HOME / "opt/factorio-preview-toolkit-linux-v0.1.74"
BG_CMD        = "./factorio-preview-toolkit"

# `factorio` on PATH is the default-instance launcher (same optimization wrapper
# + opt/factorio / instances/default paths as the default .desktop entry).
# FACTORIO_PAT matches that instance's running binary specifically, so other
# factorio instances are not caught by spawn/kill.
FACTORIO_PAT  = r"opt/factorio/bin/x64/factorio"

# Stream firefox runs in its own profile + process so it never merges with, or
# closes, personal browsing. Wayland firefox ignores --class for the WM (windows
# still report resourceClass "firefox"), so it is kept purely as a unique cmdline
# marker for pgrep, and windows are matched by pid, not class. session restore is
# disabled via the profile's user.js, so it only ever shows the URLs below.
STREAM_FF_PROFILE = "stream"
STREAM_FF_MARKER  = "--class=stream-ff"

# ff3 (twitch) before ff1 -> claim twitch by caption first, ff1 = the remaining
# stream firefox window. streamFf: restrict the match to stream-profile pids.
TARGETS = [
    {"id": "gw",    "out": OUT1, "cls": "org.kde.gwenview"},
    {"id": "chat",  "out": OUT1, "clsRe": "chatterino"},
    {"id": "ff3",   "out": OUT3, "cls": "firefox", "streamFf": True,
     "capRe": "creator dashboard|twitch"},
    {"id": "ff1",   "out": OUT1, "cls": "firefox", "streamFf": True},
    {"id": "vesk",  "out": OUT3, "cls": "vesktop"},
    {"id": "obs",   "out": OUT3, "clsRe": "obsproject"},
    {"id": "kit",   "out": OUT3, "cls": KITTY_CLASS},
    {"id": "split", "out": OUT3, "clsRe": "libresplit", "above": True},
]
TARGET_OUTS = sorted({OUT1, OUT3})

# libresplit global shortcuts: (desktop component, friendly name, key code)
HOTKEY_BINDINGS = [
    ("libresplit-startorsplit.desktop", "LibreSplit Start/Split",   92),
    ("libresplit-stoporreset.desktop",  "LibreSplit Stop/Reset",    16777273),
    ("libresplit-cancel.desktop",       "LibreSplit Cancel",        16777272),
    ("libresplit-unsplit.desktop",      "LibreSplit Unsplit",       16777264),
    ("libresplit-skipsplit.desktop",    "LibreSplit Skip Split",    16777266),
    ("libresplit-resetrestart.desktop", "LibreSplit Reset+Restart", 16777267),  # F4
]

# close: window classes belonging to the stream layout. firefox is a candidate by
# class but gated by pid (stream profile only) so personal browsing is never closed.
CLOSE_CLASS_RE = "gwenview|chatterino|firefox|vesktop|obsproject|stream-bg-factorio|libresplit"

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)-5s %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger("stream")


# --- KWin scripting -----------------------------------------------------------
JS_HELPERS = r"""
function match(w, t) {
  if (t.cls && w.resourceClass !== t.cls) return false;
  if (t.clsRe && !new RegExp(t.clsRe, 'i').test(w.resourceClass)) return false;
  if (t.capRe && !new RegExp(t.capRe, 'i').test(w.caption)) return false;
  if (t.pids && t.pids.indexOf(w.pid) === -1) return false;
  return true;
}
"""

_call = 0


def _parse_stream(out: str, sentinel: str) -> tuple[list[str], bool]:
    """Pull STREAM: lines out of journal text; stop at (and flag) the sentinel."""
    lines: list[str] = []
    for raw in out.splitlines():
        s = raw.replace("\t", "").strip()
        if s.startswith("js: "):
            s = s[4:]
        if not s.startswith("STREAM:"):
            continue
        s = s[len("STREAM:"):].strip()
        if s == sentinel:
            return lines, True
        lines.append(s)
    return lines, False


def kwin_run(js: str, timeout: float = KWIN_TIMEOUT) -> list[str]:
    """Run KWin JS, return STREAM:-prefixed print() lines from journal.

    print() output lands in the kwin journal asynchronously, so we append a
    unique end sentinel and poll the journal until it appears, instead of
    sleeping a fixed guess. `timeout` is the backstop if it never arrives.
    """
    global _call
    _call += 1
    name = f"streamctl-{os.getpid()}-{_call}"
    sentinel = f"__END__ {name}"
    path = f"/tmp/stream-kwin-{os.getpid()}.js"
    Path(path).write_text(JS_HELPERS + "\n" + js + f"\nprint('STREAM: {sentinel}');\n")
    since = int(time.time())
    sid = ""
    try:
        r = subprocess.run(
            ["qdbus", "org.kde.KWin", "/Scripting",
             "org.kde.kwin.Scripting.loadScript", path, name],
            capture_output=True, text=True,
        )
        sid = r.stdout.strip()
        if not sid:
            log.warning("loadScript empty: %s", r.stderr.strip())
            return []
        subprocess.run(
            ["qdbus", "org.kde.KWin", f"/Scripting/Script{sid}",
             "org.kde.kwin.Script.run"],
            capture_output=True,
        )
        deadline = time.monotonic() + timeout
        while True:
            out = subprocess.run(
                ["journalctl", "--user-unit", "plasma-kwin_wayland.service",
                 "--since", f"@{since}", "-o", "cat", "--no-pager"],
                capture_output=True, text=True,
            ).stdout
            lines, seen = _parse_stream(out, sentinel)
            if seen:
                return lines
            if time.monotonic() >= deadline:
                log.warning("kwin_run: no sentinel within %.1fs (%s)", timeout, name)
                return lines
            time.sleep(0.1)
    finally:
        if sid:
            subprocess.run(
                ["qdbus", "org.kde.KWin", "/Scripting",
                 "org.kde.kwin.Scripting.unloadScript", name],
                capture_output=True,
            )


def kwin_shortcut(name: str) -> None:
    subprocess.run(
        ["qdbus", "org.kde.kglobalaccel", "/component/kwin",
         "org.kde.kglobalaccel.Component.invokeShortcut", name],
        capture_output=True,
    )


# --- Geometry -----------------------------------------------------------------
def get_outputs() -> dict:
    js = """
for (const s of workspace.screens) {
  const g = s.geometry;
  print('STREAM: OUT ' + JSON.stringify({name: s.name, x: g.x, y: g.y, w: g.width, h: g.height}));
}
"""
    out: dict = {}
    for line in kwin_run(js):
        if line.startswith("OUT "):
            d = json.loads(line[4:])
            out[d["name"]] = d
    return out


def _divide(start: int, size: int, weights: list[int]) -> list[tuple[int, int]]:
    """Split [start, start+size) into len(weights) segments proportional to the
    weights. Cumulative rounding keeps segments gap-free and the last edge exact."""
    total = sum(weights)
    edges, cum = [start], 0
    for w in weights:
        cum += w
        edges.append(start + size * cum // total)
    return [(edges[i], edges[i + 1] - edges[i]) for i in range(len(weights))]


def _cols(rect: tuple, *weights: int) -> list[tuple]:
    x, y, w, h = rect
    return [(cx, y, cw, h) for cx, cw in _divide(x, w, list(weights))]


def _rows(rect: tuple, *weights: int) -> list[tuple]:
    x, y, w, h = rect
    return [(x, ry, w, rh) for ry, rh in _divide(y, h, list(weights))]


def compute_rects(outputs: dict) -> dict:
    def rect(o):
        return (o["x"], o["y"], o["w"], o["h"])

    o1, o3 = outputs[OUT1], outputs[OUT3]
    gw, chat, ff1 = _cols(rect(o1), 1, 1, 1)
    left, right = _cols(rect(o3), 1, 1)
    kit, obs = _rows(left, 1, 4)        # 20% / 80%
    vesk, ff3 = _rows(right, 1, 2)      # 1/3 / 2/3
    return {
        "gw": gw, "chat": chat, "ff1": ff1,
        "kit": kit, "obs": obs,
        "vesk": vesk, "ff3": ff3,
        "split": (o3["x"], o3["y"], SPLIT_W, SPLIT_H),
    }


# --- Spawn --------------------------------------------------------------------
def proc_running(name: str) -> bool:
    return subprocess.run(["pgrep", "-x", name], capture_output=True).returncode == 0


def launch(cmd: list[str]) -> None:
    log.info("spawn: %s", " ".join(shlex.quote(c) for c in cmd))
    subprocess.Popen(cmd, start_new_session=True,
                     stdin=subprocess.DEVNULL,
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def stream_ff_pids() -> list[int]:
    """pids of the stream-profile firefox instance, found by its unique cmdline
    marker (deterministic and stateless -- no pid file to go stale)."""
    r = subprocess.run(["pgrep", "-f", "--", STREAM_FF_MARKER],
                       capture_output=True, text=True)
    return [int(p) for p in r.stdout.split() if p.isdigit()]


def stream_targets() -> list[dict]:
    """TARGETS with the live stream-firefox pids injected, so match() can pin the
    firefox targets to the stream profile instead of personal browsing."""
    pids = stream_ff_pids()
    return [{**t, "pids": pids} if t.get("streamFf") else t for t in TARGETS]


def launch_factorio() -> None:
    log.info("=== factorio ===")
    if _pids(FACTORIO_PAT):
        log.info("running: factorio")
    else:
        launch(["factorio"])


def spawn_apps() -> None:
    log.info("=== spawn ===")
    for name, cmd in [
        ("gwenview",   ["gwenview", str(STREAM_IMAGE)]),
        ("chatterino", ["chatterino"]),
        ("vesktop",    ["vesktop"]),
        ("obs",        ["obs"]),
        ("libresplit", ["libresplit"]),
    ]:
        if proc_running(name):
            log.info("running: %s", name)
        else:
            launch(cmd)
    if stream_ff_pids():
        log.info("running: stream firefox")
    else:
        # one --no-remote invocation: it can't share an instance across calls, so
        # all stream windows/tabs are opened here. ff1+ff2 share a window (tabs),
        # twitch is its own window.
        launch(["firefox", "-P", STREAM_FF_PROFILE, "--no-remote", STREAM_FF_MARKER,
                "--new-window", STREAM_FF1, "--new-tab", STREAM_FF2,
                "--new-window", STREAM_TWITCH])
    launch(["kitty", f"--class={KITTY_CLASS}", "-d", str(BG_DIR),
            "--", "bash", "-c", f"{BG_CMD}; exec bash"])


# --- Place --------------------------------------------------------------------
def activate_on(out: str) -> bool:
    """Activate a target window on `out` so the next layout shortcut lands there.

    The Krohnkite layout shortcut applies to the *active* screen, so a window on
    `out` must be active before we fire it. Returns True if one was found.
    """
    targets = [t for t in stream_targets() if t["out"] == out]
    js = f"""
const TARGETS = {json.dumps(targets)};
const all = workspace.windowList().filter(w => w.normalWindow && !w.minimized);
const screen = workspace.screens.find(s => s.name === '{out}');
let w = all.find(x => x.output && x.output.name === '{out}' && TARGETS.some(t => match(x, t)));
if (!w && screen) {{
  w = all.find(x => TARGETS.some(t => match(x, t)));
  if (w) {{
    if (w.tile) w.tile = null;
    workspace.sendClientToScreen(w, screen);
  }}
}}
if (w) {{
  workspace.activeWindow = w;
  print('STREAM: FL ok {out} ' + JSON.stringify(w.caption));
}} else {{
  print('STREAM: FL nowin {out}');
}}
"""
    found = False
    for line in kwin_run(js):
        log.info("  %s", line)
        if line.startswith(f"FL ok {out}"):
            found = True
    return found


def engage_float(out: str) -> None:
    """Switch `out` to Krohnkite floating layout. Caller must ensure `out` is NOT
    already floating -- firing the shortcut when already floating would toggle it
    back OFF on this fork. The place loop re-checks drift after, so no settle here."""
    if activate_on(out):
        kwin_shortcut("KrohnkiteFloatingLayout")


def place(rects: dict) -> list[str]:
    enriched = [{**t, "rx": rects[t["id"]][0], "ry": rects[t["id"]][1],
                 "rw": rects[t["id"]][2], "rh": rects[t["id"]][3]}
                for t in stream_targets()]
    js = f"""
const TARGETS = {json.dumps(enriched)};
const all = workspace.windowList().filter(w => w.normalWindow);
const claimed = new Set();
const missing = [];
for (const t of TARGETS) {{
  const w = all.find(x => !claimed.has(x) && match(x, t));
  if (!w) {{ missing.push(t.id); continue; }}
  claimed.add(w);
  const screen = workspace.screens.find(s => s.name === t.out);
  if (screen && (!w.output || w.output.name !== t.out)) {{
    workspace.sendClientToScreen(w, screen);
  }}
  if (w.tile) w.tile = null;
  if (w.minimized) w.minimized = false;
  if (w.fullScreen) w.fullScreen = false;
  w.frameGeometry = {{x: t.rx, y: t.ry, width: t.rw, height: t.rh}};
  if (t.above) w.keepAbove = true;
}}
print('STREAM: MISS ' + missing.join(','));
"""
    missing: list[str] = []
    for line in kwin_run(js):
        if line.startswith("MISS "):
            missing = [x for x in line[5:].split(",") if x]
        else:
            log.info("  %s", line)
    return missing


def verify(rects: dict) -> list[str]:
    """Read back placed windows; return outputs whose windows drifted from the
    target position (= Krohnkite re-tiled them, i.e. that output isn't floating)."""
    enriched = [{**t, "rx": rects[t["id"]][0], "ry": rects[t["id"]][1]}
                for t in stream_targets()]
    js = f"""
const TARGETS = {json.dumps(enriched)};
const TOL = {GEOM_TOL};
const all = workspace.windowList().filter(w => w.normalWindow);
const claimed = new Set();
const drift = new Set();
for (const t of TARGETS) {{
  const w = all.find(x => !claimed.has(x) && match(x, t));
  if (!w) continue;
  claimed.add(w);
  const g = w.frameGeometry;
  if (Math.abs(g.x - t.rx) > TOL || Math.abs(g.y - t.ry) > TOL) drift.add(t.out);
}}
print('STREAM: DRIFT ' + Array.from(drift).join(','));
"""
    drift: list[str] = []
    for line in kwin_run(js):
        if line.startswith("DRIFT "):
            drift = [x for x in line[6:].split(",") if x]
        else:
            log.info("  %s", line)
    return drift


def settle_drift(rects: dict, timeout: float = 2.0) -> list[str]:
    """Poll verify() until the read-back is stable across two consecutive reads.

    Krohnkite re-tiles within ~a frame of place() setting geometry; a single
    early read can catch the pre-retile position and miss the drift. Waiting for
    two equal reads is the real signal that no further reaction is coming --
    replacing a fixed post-place sleep. Returns the stable drift set (or the last
    read on timeout)."""
    deadline = time.monotonic() + timeout
    prev: list[str] | None = None
    while time.monotonic() < deadline:
        cur = verify(rects)
        if prev is not None and set(cur) == set(prev):
            return cur
        prev = cur
        time.sleep(0.15)
    return prev or []


def minimize_extras() -> None:
    log.info("=== minimize ===")
    js = f"""
const TARGETS = {json.dumps(stream_targets())};
const TARGET_OUT = new Set({json.dumps(TARGET_OUTS)});
const all = workspace.windowList().filter(w => w.normalWindow);
const claimed = new Set();
for (const t of TARGETS) {{
  const w = all.find(x => !claimed.has(x) && match(x, t));
  if (w) claimed.add(w);
}}
let n = 0;
for (const w of all) {{
  if (claimed.has(w)) continue;
  if (w.output && TARGET_OUT.has(w.output.name)) {{ w.minimized = true; n++; }}
}}
print('STREAM: MIN ' + n);
"""
    for line in kwin_run(js):
        log.info("  %s", line)


def place_phase() -> bool:
    log.info("=== place ===")
    outputs = get_outputs()
    for name, g in outputs.items():
        log.info("  output %s: %dx%d @ (%d,%d)", name, g["w"], g["h"], g["x"], g["y"])
    if OUT1 not in outputs or OUT3 not in outputs:
        log.error("missing output: need %s & %s, have %s", OUT1, OUT3, list(outputs))
        return False
    rects = compute_rects(outputs)

    # Self-correcting loop: place() sets geometry, verify() reads it back. If an
    # output's windows drifted, Krohnkite re-tiled them -> that output isn't
    # floating, so engage float ONCE (guarded: never fire when already floating,
    # which would toggle it back off on this fork).
    floated: set[str] = set()
    deadline = time.monotonic() + TIMEOUT
    attempt = 0
    while time.monotonic() < deadline:
        attempt += 1
        log.info("--- attempt %d ---", attempt)
        missing = place(rects)
        drift = settle_drift(rects)  # poll until read-back stabilizes
        if not missing and not drift:
            log.info("ALL PLACED")
            return True
        for out in (OUT1, OUT3):
            if out in drift and out not in floated:
                log.info("output %s tiling -> engage float", out)
                engage_float(out)
                floated.add(out)
        log.info("missing=%s drift=%s, retry", missing, drift)
    log.warning("TIMEOUT after %d attempts", attempt)
    return False


# --- Hotkeys (libresplit global shortcuts) ------------------------------------
def _busctl(*args: str) -> None:
    subprocess.run(["busctl", "--user", "call", "org.kde.kglobalaccel",
                    "/kglobalaccel", "org.kde.KGlobalAccel", *args],
                   capture_output=True)


def hotkeys(enable: bool) -> None:
    log.info("=== hotkeys %s ===", "on" if enable else "off")
    for comp, friendly, key in HOTKEY_BINDINGS:
        aid = ("4", comp, "_launch", friendly, friendly)  # the "as" actionId array
        if enable:
            _busctl("doRegister", "as", *aid)
            _busctl("setForeignShortcut", "asai", *aid, "1", str(key))
            # setForeignShortcut only stores keys in config; a cold action (added
            # after login) is never grabbed until next login. setShortcut with
            # SetPresent=2 marks the action present -> setActive() -> registerKey
            # = live grab, no relogin. Keys are passed as "ai" (plain ints), the
            # SAME marshalling as setForeignShortcut. Do NOT use setShortcutKeys:
            # it takes QSet<QKeySequence> ("a(ai)") and a wrong inner type makes
            # libdbus abort the kglobalacceld process -- which on Wayland is KWin,
            # crashing the whole session.
            _busctl("setShortcut", "asaiu", *aid, "1", str(key), "2")
        else:
            _busctl("setForeignShortcut", "asai", *aid, "0")
        log.info("  %s %s", "bind" if enable else "unbind", friendly)


# --- Close / kill orphans -----------------------------------------------------
def find_kitty_pid() -> int:
    """Walk up the process tree to find the kitty terminal this script runs in,
    so `close` doesn't close it. Returns 0 if not launched from kitty."""
    pid = os.getpid()
    while pid > 1:
        try:
            r = subprocess.run(["ps", "-o", "comm=,ppid=", "-p", str(pid)],
                               capture_output=True, text=True)
            parts = r.stdout.split()
            if not parts:
                break
            comm, ppid = parts[0], parts[-1]
        except Exception:
            break
        if comm == "kitty":
            return pid
        pid = int(ppid) if ppid.isdigit() else 0
    return 0


def _pids(pattern: str) -> list[str]:
    """pids whose full cmdline matches `pattern` (pgrep -f), excluding this script."""
    r = subprocess.run(["pgrep", "-f", pattern], capture_output=True, text=True)
    return [p for p in r.stdout.split() if p.isdigit() and int(p) != os.getpid()]


def wait_gone(pattern: str, timeout: float = 4.0) -> bool:
    """Poll until no process matches `pattern`, or timeout. The real signal that
    a SIGTERM'd process has actually exited, replacing a fixed post-kill sleep."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if not _pids(pattern):
            return True
        time.sleep(0.1)
    return False


def kill_pattern(pattern: str, label: str) -> bool:
    """Kill processes matching `pattern` (pgrep -f). Returns True if any were hit."""
    pids = _pids(pattern)
    if pids:
        log.info("  kill %s: %s", label, " ".join(pids))
        subprocess.run(["kill", *pids], capture_output=True)
    return bool(pids)


# obs lives in the nix store; match its exact exe path, not the launcher.
OBS_PAT = r"/nix/store.*/obs$"


def kill_obs() -> None:
    pids = _pids(OBS_PAT)
    if pids:
        log.info("  kill obs: %s", " ".join(pids))
        subprocess.run(["kill", *pids], capture_output=True)


def close_windows() -> None:
    log.info("=== close ===")
    kitty_pid = find_kitty_pid()
    js = f"""
const KITTYPID = {kitty_pid};
const CLASS_RE = /{CLOSE_CLASS_RE}/i;
const FF_PIDS = {json.dumps(stream_ff_pids())};
const wins = workspace.windowList();
let n = 0;
for (const w of wins) {{
  if (!w || !w.normalWindow) continue;
  const cls = w.resourceClass || "";
  const cap = w.caption || "";
  if (!CLASS_RE.test(cls)) {{ print("STREAM: SKIP " + cls); continue; }}
  if (KITTYPID && w.pid === KITTYPID) {{ print("STREAM: SKIP-SELF " + cls); continue; }}
  if (cls === "firefox" && FF_PIDS.indexOf(w.pid) === -1) {{
    print("STREAM: SKIP-FF " + JSON.stringify(cap)); continue;
  }}
  print("STREAM: CLOSE " + cls + " cap=\\"" + cap + "\\"");
  w.closeWindow();
  n++;
}}
print("STREAM: CLOSE_DONE n=" + n);
"""
    for line in kwin_run(js):
        if line.startswith(("CLOSE", "SKIP")):
            log.info("  %s", line)


# firefox scoped to the stream marker so personal browsing isn't flagged a survivor
SURV_PAT = ("gwenview", "chatterino", "libresplit", STREAM_FF_MARKER, "/obs ",
            "electron", "stream-bg", "factorio-preview", FACTORIO_PAT, "vesktop")


def survivors() -> list[str]:
    r = subprocess.run(["ps", "-eo", "pid,comm,args"], capture_output=True, text=True)
    return [ln for ln in r.stdout.splitlines()
            if any(p in ln for p in SURV_PAT) and str(os.getpid()) not in ln.split()[:1]]


def survivors_report(timeout: float = 5.0) -> None:
    """Poll until the stream procs have died (or timeout), then report whatever
    is left -- replaces a blind post-kill sleep with the actual exit signal."""
    deadline = time.monotonic() + timeout
    surv = survivors()
    while surv and time.monotonic() < deadline:
        time.sleep(0.2)
        surv = survivors()
    if surv:
        log.info("=== survivors ===")
        for ln in surv:
            log.info("  %s", ln)
    else:
        log.info("=== all clear ===")


# --- Action runner ------------------------------------------------------------
GROUPS = {
    "up":   ["factorio", "spawn", "place", "minimize", "keys"],
    "down": ["close", "kill", "nokeys"],
}
ACTIONS = ["factorio", "spawn", "place", "minimize", "close", "kill", "keys", "nokeys"]
# Fixed run order, regardless of token order. `factorio` runs before `spawn` so
# the game window exists before OBS starts (game-capture source binds it). `kill`
# is split so the toolkit pre-kill runs before `close` (lets the bg kitty's shell
# go idle -> closes without a "still running" confirm) and factorio/vesktop/obs
# are killed after.
RUN_ORDER = ["factorio", "spawn", "place", "minimize", "kill", "close",
             "kill-post", "keys", "nokeys"]


def expand(tokens: list[str]) -> set[str]:
    selected: set[str] = set()
    for tok in tokens:
        if tok in GROUPS:
            selected.update(GROUPS[tok])
        elif tok in ACTIONS:
            selected.add(tok)
        else:
            valid = ", ".join(list(GROUPS) + ACTIONS)
            raise SystemExit(f"streamctl: unknown token '{tok}'. valid: {valid}")
    if "keys" in selected and "nokeys" in selected:
        raise SystemExit("streamctl: 'keys' and 'nokeys' are contradictory")
    return selected


def run(selected: set[str]) -> None:
    for step in RUN_ORDER:
        if step == "factorio" and "factorio" in selected:
            launch_factorio()
        elif step == "spawn" and "spawn" in selected:
            spawn_apps()
        elif step == "place" and "place" in selected:
            place_phase()
        elif step == "minimize" and "minimize" in selected:
            minimize_extras()
        elif step == "kill" and "kill" in selected:
            # pre-kill the preview toolkit before closing its kitty, then wait for
            # it to actually exit so the bg kitty's shell goes idle (-> close won't
            # hit a "still running" confirm)
            if kill_pattern("factorio-preview-toolkit", "factorio-preview-toolkit"):
                wait_gone("factorio-preview-toolkit", timeout=3)
        elif step == "close" and "close" in selected:
            close_windows()
        elif step == "kill-post" and "kill" in selected:
            kill_pattern("vesktop", "vesktop")
            kill_obs()
            kill_pattern(FACTORIO_PAT, "factorio")
            survivors_report()  # polls for actual exit before reporting
        elif step == "keys" and "keys" in selected:
            hotkeys(True)
        elif step == "nokeys" and "nokeys" in selected:
            hotkeys(False)


def main() -> None:
    p = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("tokens", nargs="*",
                   help="actions/groups: " + ", ".join(list(GROUPS) + ACTIONS))
    p.add_argument("-v", "--verbose", action="store_true", help="debug logging")
    args = p.parse_args()

    if args.verbose:
        log.setLevel(logging.DEBUG)
    if not args.tokens:
        p.print_help()
        return

    selected = expand(args.tokens)
    log.info("=== streamctl %s ===", " ".join(args.tokens))
    run(selected)
    log.info("=== done ===")


if __name__ == "__main__":
    main()
