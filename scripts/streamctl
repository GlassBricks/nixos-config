#!/usr/bin/env python3
"""Stream control: bring the stream layout up or tear it down via KWin scripting.

Additive token bag - list any actions to run; `up`/`down` are bundle aliases.

  Groups   up   = spawn place minimize keys     (old stream-setup + libresplit-hotkeys-on)
           down = close kill nokeys             (old stream-close  + libresplit-hotkeys-off)

  Actions  spawn     launch the stream apps
           place     place windows across monitors
           minimize  minimize extra windows
           close     close stream windows via KWin
           kill      kill orphan procs (toolkit, vesktop, obs)
           keys      bind libresplit hotkeys (ON)
           nokeys    unbind libresplit hotkeys (OFF)

Layout (place):
  OUT1 (DP-3, left)   : gw | chat | ff1                - equal thirds
  OUT2 (DP-1, center) : untouched
  OUT3 (DP-2, right)  : kit  ff3 / obs  vesk           - quarters
                        + libresplit floating upper-left
  Other windows on OUT1 & OUT3 minimized.

Examples:
  streamctl up                 full setup + hotkeys ON
  streamctl down               close + kill orphans + hotkeys OFF
  streamctl spawn place keys   launch, place, hotkeys ON (no minimize)
  streamctl place minimize     re-place already-running windows
  streamctl keys / streamctl nokeys   toggle libresplit hotkeys only
"""

from __future__ import annotations

import argparse
import json
import logging
import os
import shlex
import subprocess
import time
from pathlib import Path

HOME = Path.home()
OUT1, OUT2, OUT3 = "DP-3", "DP-1", "DP-2"
KITTY_CLASS = "stream-bg-factorio"
SPLIT_W, SPLIT_H = 300, 430
TIMEOUT = 25
UNMIN_DELAY = 0.4
GEOM_TOL = 40  # px; Krohnkite re-tiling moves windows far more than this

STREAM_IMAGE  = HOME / "Documents/Factorio/RSNG+/queue1.png"
STREAM_FF1    = "https://docs.google.com/spreadsheets/d/1z6Z9Vp3Abv4sXgnAqKTJ8WCbT_7ZdupdOlDob4eHSv8/edit?gid=0#gid=0"
STREAM_FF2    = "file:///home/ben/opt/factorio-preview-toolkit-linux-v0.1.74/viewer/index.html"
STREAM_TWITCH = "https://dashboard.twitch.tv/u/glassbricks/stream-manager"
BG_DIR        = HOME / "opt/factorio-preview-toolkit-linux-v0.1.74"
BG_CMD        = "./factorio-preview-toolkit"

# ff3 (twitch) before ff1 -> claim-by-caption first, ff1 = remaining firefox
TARGETS = [
    {"id": "gw",    "out": OUT1, "cls": "org.kde.gwenview"},
    {"id": "chat",  "out": OUT1, "clsRe": "chatterino"},
    {"id": "ff3",   "out": OUT3, "cls": "firefox", "capRe": "twitch"},
    {"id": "ff1",   "out": OUT1, "cls": "firefox"},
    {"id": "vesk",  "out": OUT3, "cls": "vesktop"},
    {"id": "obs",   "out": OUT3, "clsRe": "obsproject"},
    {"id": "kit",   "out": OUT3, "cls": KITTY_CLASS},
    {"id": "split", "out": OUT3, "clsRe": "libresplit", "above": True},
]
TARGET_OUTS = sorted({OUT1, OUT3})

# libresplit global shortcuts: (desktop component, friendly name, key code)
HOTKEY_BINDINGS = [
    ("libresplit-startorsplit.desktop", "LibreSplit Start/Split",   92),
    ("libresplit-stoporreset.desktop",  "LibreSplit Stop/Reset",    16777273),
    ("libresplit-cancel.desktop",       "LibreSplit Cancel",        16777272),
    ("libresplit-unsplit.desktop",      "LibreSplit Unsplit",       16777264),
    ("libresplit-skipsplit.desktop",    "LibreSplit Skip Split",    16777266),
    ("libresplit-resetrestart.desktop", "LibreSplit Reset+Restart", 16777267),  # F4
]

# close: window classes belonging to the stream layout
CLOSE_CLASS_RE = "gwenview|chatterino|firefox|vesktop|obsproject|stream-bg-factorio|libresplit"

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)-5s %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger("stream")


# --- KWin scripting -----------------------------------------------------------
JS_HELPERS = r"""
function match(w, t) {
  if (t.cls && w.resourceClass !== t.cls) return false;
  if (t.clsRe && !new RegExp(t.clsRe, 'i').test(w.resourceClass)) return false;
  if (t.capRe && !new RegExp(t.capRe, 'i').test(w.caption)) return false;
  return true;
}
"""

_call = 0


def kwin_run(js: str, wait: float = 0.5) -> list[str]:
    """Run KWin JS, return STREAM:-prefixed print() lines from journal."""
    global _call
    _call += 1
    path = f"/tmp/stream-kwin-{os.getpid()}.js"
    Path(path).write_text(JS_HELPERS + "\n" + js)
    name = f"streamctl-{os.getpid()}-{_call}"
    since = int(time.time())
    sid = ""
    try:
        r = subprocess.run(
            ["qdbus", "org.kde.KWin", "/Scripting",
             "org.kde.kwin.Scripting.loadScript", path, name],
            capture_output=True, text=True,
        )
        sid = r.stdout.strip()
        if not sid:
            log.warning("loadScript empty: %s", r.stderr.strip())
            return []
        subprocess.run(
            ["qdbus", "org.kde.KWin", f"/Scripting/Script{sid}",
             "org.kde.kwin.Script.run"],
            capture_output=True,
        )
        time.sleep(wait)
        out = subprocess.run(
            ["journalctl", "--user-unit", "plasma-kwin_wayland.service",
             "--since", f"@{since}", "-o", "cat", "--no-pager"],
            capture_output=True, text=True,
        ).stdout
    finally:
        if sid:
            subprocess.run(
                ["qdbus", "org.kde.KWin", "/Scripting",
                 "org.kde.kwin.Scripting.unloadScript", name],
                capture_output=True,
            )

    lines: list[str] = []
    for raw in out.splitlines():
        s = raw.replace("\t", "").strip()
        if s.startswith("js: "):
            s = s[4:]
        if s.startswith("STREAM:"):
            lines.append(s[len("STREAM:"):].strip())
    return lines


def kwin_shortcut(name: str) -> None:
    subprocess.run(
        ["qdbus", "org.kde.kglobalaccel", "/component/kwin",
         "org.kde.kglobalaccel.Component.invokeShortcut", name],
        capture_output=True,
    )


# --- Geometry -----------------------------------------------------------------
def get_outputs() -> dict:
    js = """
for (const s of workspace.screens) {
  const g = s.geometry;
  print('STREAM: OUT ' + JSON.stringify({name: s.name, x: g.x, y: g.y, w: g.width, h: g.height}));
}
"""
    out: dict = {}
    for line in kwin_run(js, wait=0.2):
        if line.startswith("OUT "):
            d = json.loads(line[4:])
            out[d["name"]] = d
    return out


def compute_rects(outputs: dict) -> dict:
    o1, o3 = outputs[OUT1], outputs[OUT3]
    t = o1["w"] // 3
    t_last = o1["w"] - 2 * t
    hw, hh = o3["w"] // 2, o3["h"] // 2
    hw_last, hh_last = o3["w"] - hw, o3["h"] - hh
    return {
        "gw":    (o1["x"],         o1["y"],      t,       o1["h"]),
        "chat":  (o1["x"] + t,     o1["y"],      t,       o1["h"]),
        "ff1":   (o1["x"] + 2 * t, o1["y"],      t_last,  o1["h"]),
        "kit":   (o3["x"],         o3["y"],      hw,      hh),
        "ff3":   (o3["x"] + hw,    o3["y"],      hw_last, hh),
        "obs":   (o3["x"],         o3["y"] + hh, hw,      hh_last),
        "vesk":  (o3["x"] + hw,    o3["y"] + hh, hw_last, hh_last),
        "split": (o3["x"],         o3["y"],      SPLIT_W, SPLIT_H),
    }


# --- Spawn --------------------------------------------------------------------
def proc_running(name: str) -> bool:
    return subprocess.run(["pgrep", "-x", name], capture_output=True).returncode == 0


def launch(cmd: list[str]) -> None:
    log.info("spawn: %s", " ".join(shlex.quote(c) for c in cmd))
    subprocess.Popen(cmd, start_new_session=True,
                     stdin=subprocess.DEVNULL,
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


def spawn_apps() -> None:
    log.info("=== spawn ===")
    for name, cmd in [
        ("gwenview",   ["gwenview", str(STREAM_IMAGE)]),
        ("chatterino", ["chatterino"]),
        ("vesktop",    ["vesktop"]),
        ("obs",        ["obs"]),
        ("libresplit", ["libresplit"]),
    ]:
        if proc_running(name):
            log.info("running: %s", name)
        else:
            launch(cmd)
    launch(["firefox", "--new-window", STREAM_FF1])
    time.sleep(1.2)  # let FF1 window register, so FF2 lands as new tab
    launch(["firefox", "--new-tab", STREAM_FF2])
    launch(["firefox", "--new-window", STREAM_TWITCH])
    launch(["kitty", f"--class={KITTY_CLASS}", "-d", str(BG_DIR),
            "--", "bash", "-c", f"{BG_CMD}; exec bash"])


# --- Place --------------------------------------------------------------------
def activate_on(out: str) -> bool:
    """Activate a target window on `out` so the next layout shortcut lands there.

    The Krohnkite layout shortcut applies to the *active* screen, so a window on
    `out` must be active before we fire it. Returns True if one was found.
    """
    targets = [t for t in TARGETS if t["out"] == out]
    js = f"""
const TARGETS = {json.dumps(targets)};
const all = workspace.windowList().filter(w => w.normalWindow && !w.minimized);
const screen = workspace.screens.find(s => s.name === '{out}');
let w = all.find(x => x.output && x.output.name === '{out}' && TARGETS.some(t => match(x, t)));
if (!w && screen) {{
  w = all.find(x => TARGETS.some(t => match(x, t)));
  if (w) {{
    if (w.tile) w.tile = null;
    workspace.sendClientToScreen(w, screen);
  }}
}}
if (w) {{
  workspace.activeWindow = w;
  print('STREAM: FL ok {out} ' + JSON.stringify(w.caption));
}} else {{
  print('STREAM: FL nowin {out}');
}}
"""
    found = False
    for line in kwin_run(js, wait=0.3):
        log.info("  %s", line)
        if line.startswith(f"FL ok {out}"):
            found = True
    return found


def engage_float(out: str) -> None:
    """Switch `out` to Krohnkite floating layout (idempotent caller must ensure
    `out` is NOT already floating -- firing the shortcut when already floating
    would toggle it back OFF on this fork)."""
    if activate_on(out):
        kwin_shortcut("KrohnkiteFloatingLayout")
        time.sleep(UNMIN_DELAY)


def place(rects: dict) -> list[str]:
    enriched = [{**t, "rx": rects[t["id"]][0], "ry": rects[t["id"]][1],
                 "rw": rects[t["id"]][2], "rh": rects[t["id"]][3]}
                for t in TARGETS]
    js = f"""
const TARGETS = {json.dumps(enriched)};
const all = workspace.windowList().filter(w => w.normalWindow);
const claimed = new Set();
const missing = [];
for (const t of TARGETS) {{
  const w = all.find(x => !claimed.has(x) && match(x, t));
  if (!w) {{ missing.push(t.id); continue; }}
  claimed.add(w);
  const screen = workspace.screens.find(s => s.name === t.out);
  if (screen && (!w.output || w.output.name !== t.out)) {{
    workspace.sendClientToScreen(w, screen);
  }}
  if (w.tile) w.tile = null;
  if (w.minimized) w.minimized = false;
  if (w.fullScreen) w.fullScreen = false;
  w.frameGeometry = {{x: t.rx, y: t.ry, width: t.rw, height: t.rh}};
  if (t.above) w.keepAbove = true;
}}
print('STREAM: MISS ' + missing.join(','));
"""
    missing: list[str] = []
    for line in kwin_run(js, wait=0.6):
        if line.startswith("MISS "):
            missing = [x for x in line[5:].split(",") if x]
        else:
            log.info("  %s", line)
    return missing


def verify(rects: dict) -> list[str]:
    """Read back placed windows; return outputs whose windows drifted from the
    target position (= Krohnkite re-tiled them, i.e. that output isn't floating)."""
    enriched = [{**t, "rx": rects[t["id"]][0], "ry": rects[t["id"]][1]}
                for t in TARGETS]
    js = f"""
const TARGETS = {json.dumps(enriched)};
const TOL = {GEOM_TOL};
const all = workspace.windowList().filter(w => w.normalWindow);
const claimed = new Set();
const drift = new Set();
for (const t of TARGETS) {{
  const w = all.find(x => !claimed.has(x) && match(x, t));
  if (!w) continue;
  claimed.add(w);
  const g = w.frameGeometry;
  if (Math.abs(g.x - t.rx) > TOL || Math.abs(g.y - t.ry) > TOL) drift.add(t.out);
}}
print('STREAM: DRIFT ' + Array.from(drift).join(','));
"""
    drift: list[str] = []
    for line in kwin_run(js, wait=0.2):
        if line.startswith("DRIFT "):
            drift = [x for x in line[6:].split(",") if x]
        else:
            log.info("  %s", line)
    return drift


def minimize_extras() -> None:
    log.info("=== minimize ===")
    js = f"""
const TARGETS = {json.dumps(TARGETS)};
const TARGET_OUT = new Set({json.dumps(TARGET_OUTS)});
const all = workspace.windowList().filter(w => w.normalWindow);
const claimed = new Set();
for (const t of TARGETS) {{
  const w = all.find(x => !claimed.has(x) && match(x, t));
  if (w) claimed.add(w);
}}
let n = 0;
for (const w of all) {{
  if (claimed.has(w)) continue;
  const onTarget = w.output && TARGET_OUT.has(w.output.name);
  if (onTarget || w.resourceClass === 'firefox') {{
    w.minimized = true; n++;
  }}
}}
print('STREAM: MIN ' + n);
"""
    for line in kwin_run(js, wait=0.4):
        log.info("  %s", line)


def place_phase() -> bool:
    log.info("=== place ===")
    outputs = get_outputs()
    for name, g in outputs.items():
        log.info("  output %s: %dx%d @ (%d,%d)", name, g["w"], g["h"], g["x"], g["y"])
    if OUT1 not in outputs or OUT3 not in outputs:
        log.error("missing output: need %s & %s, have %s", OUT1, OUT3, list(outputs))
        return False
    rects = compute_rects(outputs)

    # Self-correcting loop: place() sets geometry, verify() reads it back. If an
    # output's windows drifted, Krohnkite re-tiled them -> that output isn't
    # floating, so engage float ONCE (guarded: never fire when already floating,
    # which would toggle it back off on this fork).
    floated: set[str] = set()
    deadline = time.monotonic() + TIMEOUT
    attempt = 0
    while time.monotonic() < deadline:
        attempt += 1
        log.info("--- attempt %d ---", attempt)
        missing = place(rects)
        time.sleep(0.6)
        drift = verify(rects)
        if not missing and not drift:
            log.info("ALL PLACED")
            return True
        for out in (OUT1, OUT3):
            if out in drift and out not in floated:
                log.info("output %s tiling -> engage float", out)
                engage_float(out)
                floated.add(out)
        log.info("missing=%s drift=%s, retry", missing, drift)
        time.sleep(0.5)
    log.warning("TIMEOUT after %d attempts", attempt)
    return False


# --- Hotkeys (libresplit global shortcuts) ------------------------------------
def _busctl(*args: str) -> None:
    subprocess.run(["busctl", "--user", "call", "org.kde.kglobalaccel",
                    "/kglobalaccel", "org.kde.KGlobalAccel", *args],
                   capture_output=True)


def hotkeys(enable: bool) -> None:
    log.info("=== hotkeys %s ===", "on" if enable else "off")
    for comp, friendly, key in HOTKEY_BINDINGS:
        aid = ("4", comp, "_launch", friendly, friendly)  # the "as" actionId array
        if enable:
            _busctl("doRegister", "as", *aid)
            _busctl("setForeignShortcut", "asai", *aid, "1", str(key))
            # setForeignShortcut only stores keys in config; a cold action (added
            # after login) is never grabbed until next login. setShortcut with
            # SetPresent=2 marks the action present -> setActive() -> registerKey
            # = live grab, no relogin. Keys are passed as "ai" (plain ints), the
            # SAME marshalling as setForeignShortcut. Do NOT use setShortcutKeys:
            # it takes QSet<QKeySequence> ("a(ai)") and a wrong inner type makes
            # libdbus abort the kglobalacceld process -- which on Wayland is KWin,
            # crashing the whole session.
            _busctl("setShortcut", "asaiu", *aid, "1", str(key), "2")
        else:
            _busctl("setForeignShortcut", "asai", *aid, "0")
        log.info("  %s %s", "bind" if enable else "unbind", friendly)


# --- Close / kill orphans -----------------------------------------------------
def find_kitty_pid() -> int:
    """Walk up the process tree to find the kitty terminal this script runs in,
    so `close` doesn't close it. Returns 0 if not launched from kitty."""
    pid = os.getpid()
    while pid > 1:
        try:
            r = subprocess.run(["ps", "-o", "comm=,ppid=", "-p", str(pid)],
                               capture_output=True, text=True)
            parts = r.stdout.split()
            if not parts:
                break
            comm, ppid = parts[0], parts[-1]
        except Exception:
            break
        if comm == "kitty":
            return pid
        pid = int(ppid) if ppid.isdigit() else 0
    return 0


def kill_pattern(pattern: str, label: str) -> None:
    """Kill processes matching `pattern` (pgrep -f), excluding this script."""
    r = subprocess.run(["pgrep", "-f", pattern], capture_output=True, text=True)
    pids = [p for p in r.stdout.split() if p and int(p) != os.getpid()]
    if pids:
        log.info("  kill %s: %s", label, " ".join(pids))
        subprocess.run(["kill", *pids], capture_output=True)


def kill_obs() -> None:
    """obs lives in the nix store; match its exact exe path, not the launcher."""
    r = subprocess.run(["pgrep", "-af", r"/nix/store.*/obs$"],
                       capture_output=True, text=True)
    pids = [line.split()[0] for line in r.stdout.splitlines()
            if line and int(line.split()[0]) != os.getpid()]
    if pids:
        log.info("  kill obs: %s", " ".join(pids))
        subprocess.run(["kill", *pids], capture_output=True)


def close_windows() -> None:
    log.info("=== close ===")
    kitty_pid = find_kitty_pid()
    js = f"""
const KITTYPID = {kitty_pid};
const CLASS_RE = /{CLOSE_CLASS_RE}/i;
const wins = workspace.windowList();
let n = 0;
for (const w of wins) {{
  if (!w || !w.normalWindow) continue;
  const cls = w.resourceClass || "";
  if (!CLASS_RE.test(cls)) {{ print("STREAM: SKIP " + cls); continue; }}
  if (KITTYPID && w.pid === KITTYPID) {{ print("STREAM: SKIP-SELF " + cls); continue; }}
  print("STREAM: CLOSE " + cls + " cap=\\"" + (w.caption || "") + "\\"");
  w.closeWindow();
  n++;
}}
print("STREAM: CLOSE_DONE n=" + n);
"""
    for line in kwin_run(js, wait=2.0):
        if line.startswith(("CLOSE", "SKIP")):
            log.info("  %s", line)


def survivors_report() -> None:
    r = subprocess.run(["ps", "-eo", "pid,comm,args"], capture_output=True, text=True)
    pat = ("gwenview", "chatterino", "libresplit", "firefox", "/obs ",
           "electron", "stream-bg", "factorio-preview", "vesktop")
    surv = [ln for ln in r.stdout.splitlines()
            if any(p in ln for p in pat) and str(os.getpid()) not in ln.split()[:1]]
    if surv:
        log.info("=== survivors ===")
        for ln in surv:
            log.info("  %s", ln)
    else:
        log.info("=== all clear ===")


# --- Action runner ------------------------------------------------------------
GROUPS = {
    "up":   ["spawn", "place", "minimize", "keys"],
    "down": ["close", "kill", "nokeys"],
}
ACTIONS = ["spawn", "place", "minimize", "close", "kill", "keys", "nokeys"]
# Fixed run order, regardless of token order. `kill` is split so the toolkit
# pre-kill runs before `close` (lets the bg kitty's shell go idle -> closes
# without a "still running" confirm) and vesktop/obs are killed after.
RUN_ORDER = ["spawn", "place", "minimize", "kill", "close", "kill-post",
             "keys", "nokeys"]


def expand(tokens: list[str]) -> set[str]:
    selected: set[str] = set()
    for tok in tokens:
        if tok in GROUPS:
            selected.update(GROUPS[tok])
        elif tok in ACTIONS:
            selected.add(tok)
        else:
            valid = ", ".join(list(GROUPS) + ACTIONS)
            raise SystemExit(f"streamctl: unknown token '{tok}'. valid: {valid}")
    if "keys" in selected and "nokeys" in selected:
        raise SystemExit("streamctl: 'keys' and 'nokeys' are contradictory")
    return selected


def run(selected: set[str]) -> None:
    for step in RUN_ORDER:
        if step == "spawn" and "spawn" in selected:
            spawn_apps()
        elif step == "place" and "place" in selected:
            place_phase()
        elif step == "minimize" and "minimize" in selected:
            minimize_extras()
        elif step == "kill" and "kill" in selected:
            # pre-kill the preview toolkit before closing its kitty
            kill_pattern("factorio-preview-toolkit", "factorio-preview-toolkit")
            time.sleep(0.5)
        elif step == "close" and "close" in selected:
            close_windows()
        elif step == "kill-post" and "kill" in selected:
            kill_pattern("vesktop", "vesktop")
            kill_obs()
            time.sleep(3)
            survivors_report()
        elif step == "keys" and "keys" in selected:
            hotkeys(True)
        elif step == "nokeys" and "nokeys" in selected:
            hotkeys(False)


def main() -> None:
    p = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("tokens", nargs="*",
                   help="actions/groups: " + ", ".join(list(GROUPS) + ACTIONS))
    p.add_argument("-v", "--verbose", action="store_true", help="debug logging")
    args = p.parse_args()

    if args.verbose:
        log.setLevel(logging.DEBUG)
    if not args.tokens:
        p.print_help()
        return

    selected = expand(args.tokens)
    log.info("=== streamctl %s ===", " ".join(args.tokens))
    run(selected)
    log.info("=== done ===")


if __name__ == "__main__":
    main()
